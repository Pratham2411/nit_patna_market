# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/campus-market?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars

# ── Frontend origin (used in email verify links + CORS) ───────────────────────
FRONTEND_URL=http://localhost:3000

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# 1. Enable 2-Step Verification on your Google account
# 2. Go to myaccount.google.com → Security → App Passwords
# 3. Create an app password (select "Mail" + "Other"), copy the 16-char password
# 4. Paste it as SMTP_PASS below (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password

# Display name and from-address in sent emails
FROM_NAME=Campus Market
FROM_EMAIL=your_gmail@gmail.com

# Optional: connection timeout in ms (default 10000)
# SMTP_TIMEOUT_MS=10000

# ── Node environment ──────────────────────────────────────────────────────────
NODE_ENV=development
